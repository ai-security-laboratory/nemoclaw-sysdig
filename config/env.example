# Copy this file to .env (gitignored) and fill in your values.
# Never commit the .env file.

# --- NVIDIA NIM (used by NemoClaw for inference routing) ---
NVIDIA_API_KEY=

# --- Sysdig (used by future scenarios that call the Sysdig API) ---
SYSDIG_SECURE_TOKEN=
SYSDIG_URL=https://secure.sysdig.com
