# Copy this file to .env (gitignored) and fill in your values.
# Never commit the .env file.

# --- NVIDIA NIM / NemoClaw ---
NVIDIA_API_KEY=
NEMO_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Sysdig ---
SYSDIG_SECURE_TOKEN=
SYSDIG_URL=https://secure.sysdig.com

# --- Deployment ---
# Path to SSH private key used to reach target VMs
SSH_KEY_PATH=~/.ssh/id_ed25519
# Default SSH user on target VMs
SSH_USER=ubuntu

# --- Test config ---
# Log level for test runs: DEBUG, INFO, WARNING, ERROR
TEST_LOG_LEVEL=INFO
